APP_ENV=local
APP_NAME=Utilidades Facturas

DATA_DIR=data
INBOX_DIR=data/inbox
EXPORT_DIR=data/exports
DATABASE_PATH=data/app.db

DEFAULT_PARSER=generic

STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_PORT=8501

OCR_ENABLED=true
OCR_LANGUAGE=spa+eng
OCR_RENDER_DPI=200
OCR_MIN_TEXT_LENGTH=30
OCR_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

FORCE_DEFAULT_CUSTOMER_FOR_FACTURAS=false
DEFAULT_CUSTOMER_NAME=
DEFAULT_CUSTOMER_TAX_ID=
DEFAULT_CUSTOMER_POSTAL_CODE=
